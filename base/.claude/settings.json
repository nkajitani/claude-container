{
  "permissions": {
    "deny": [
      "Read(./.env)"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "sh /root/.claude/statusline-command.sh"
  },
  "language": "japanese",
  "minimumVersion": "stable",
  "theme": "dark",
  "dangerouslyDisableSandbox": true,
  "defaultMode": "acceptEdits"
}
